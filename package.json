{
  "name": "ralph",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@ralph/web",
    "dev:api": "turbo run start:dev --filter=@ralph/api",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@ralph/web",
    "build:api": "turbo run build --filter=@ralph/api",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.5.0"
  }
}
