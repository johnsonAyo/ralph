{
  "name": "@ralph/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "TS_NODE_TRANSPILE_ONLY=1 TS_NODE_PROJECT=tsconfig.json node --test --require ts-node/register/transpile-only --require tsconfig-paths/register test/extraction/*.test.ts test/ai/*.test.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@ralph/shared": "workspace:*",
    "@supabase/supabase-js": "^2.86.0",
    "cheerio": "^1.2.0",
    "openai": "^6.10.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "stripe": "^22.3.0",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.14",
    "@ralph/eslint-config": "workspace:*",
    "@ralph/typescript-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.4",
    "eslint": "^9.29.0",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
