PORT=PORT
WEB_ORIGIN=WEB_ORIGIN

SUPABASE_URL=SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=OPENAI_MODEL
# Optional: override the model used for generic listing-page extraction.
OPENAI_EXTRACTION_MODEL=OPENAI_EXTRACTION_MODEL

# Ollama — optional local LLM fallback used when OpenAI is unavailable.
# Leave OLLAMA_URL blank to disable Ollama.
OLLAMA_URL=OLLAMA_URL
OLLAMA_MODEL=OLLAMA_MODEL

# Stripe — create prices in dashboard with lookup keys: starter, buyer, protected
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
WEB_URL=WEB_URL

# Scrape.do — proxy/scraping API used to fetch Copart/IAA listings past their WAF.
# Free tier: 1,000 successful calls/month (residential proxies + JS render included).
# Get a token at https://dashboard.scrape.do/
SCRAPE_DO_TOKEN=your-scrape-do-token

# DVSA MOT History API — free. Register at https://documentation.history.mot.api.gov.uk/
# Gives make/model/fuel/colour + full MOT history (mileage per test, advisories).
DVSA_MOT_CLIENT_ID=your-client-id
DVSA_MOT_CLIENT_SECRET=your-client-secret
DVSA_MOT_API_KEY=your-api-key
DVSA_MOT_TOKEN_URL=DVSA_MOT_TOKEN_URL
DVSA_MOT_SCOPE=DVSA_MOT_SCOPE

RESEND_API_KEY=RESEND_API_KEY
SUPABASE_WEBHOOK_SECRET=SUPABASE_WEBHOOK_SECRET
